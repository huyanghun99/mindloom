# MindLoom 知织 — environment template
# Copy to .env and adjust as needed. NEVER commit the real .env.

NODE_ENV=development
PORT=39280

# Must be at least 16 chars. Change this in production.
APP_SECRET=development-secret-change-me-now

# Public base URL used for share links
PUBLIC_BASE_URL=http://127.0.0.1:39280

# Allow the first visitor to register as instance owner
ALLOW_SIGNUP=true

# PostgreSQL + pgvector connection (matches docker-compose db service)
DATABASE_URL=postgres://mindloom:mindloom@127.0.0.1:5432/mindloom

# Instance-wide embedding dimension (MVP: single, locked value)
EMBEDDING_DIMENSION=1536

# Storage driver: local | s3
STORAGE_DRIVER=local
UPLOAD_DIR=./data/uploads

# AI driver: mock | openai | openai-compatible | ollama | gemini
# Use "mock" for local dev / tests (no external calls).
AI_DRIVER=mock
AI_COMPLETION_MODEL=mock-chat
AI_EMBEDDING_MODEL=mock-embedding

# OpenAI-compatible credentials (only used when AI_DRIVER requires them)
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Request-level rate limits
RAG_RATE_LIMIT_PER_USER_PER_MINUTE=20
RAG_RATE_LIMIT_PER_SPACE_PER_MINUTE=60
